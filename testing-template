import { Component, OnInit, OnDestroy } from '@angular/core';
import { CommonModule } from '@angular/common';
import { Subject, takeUntil } from 'rxjs';

// Angular Material Imports
import { MatTableModule } from '@angular/material/table';
import { MatButtonModule } from '@angular/material/button';
import { MatIconModule } from '@angular/material/icon';
import { MatMenuModule } from '@angular/material/menu';
import { MatDialogModule, MatDialog } from '@angular/material/dialog';
import { MatProgressSpinnerModule } from '@angular/material/progress-spinner';
import { MatSnackBarModule, MatSnackBar } from '@angular/material/snack-bar';
import { MatTooltipModule } from '@angular/material/tooltip';

import { TemplateService } from './template.service';
import { DeleteTemplateDialogComponent } from './delete-template-dialog.component';
import { TemplateItem } from './template.model';

@Component({
  selector: 'app-manage-templates',
  standalone: true,
  imports: [
    CommonModule,
    MatTableModule,
    MatButtonModule,
    MatIconModule,
    MatMenuModule,
    MatDialogModule,
    MatProgressSpinnerModule,
    MatSnackBarModule,
    MatTooltipModule,
  ],
  template: `
    <div class="manage-templates-container">
      <!-- Header -->
      <div class="page-header">
        <button mat-icon-button class="back-btn" (click)="goBack()">
          <mat-icon>arrow_back</mat-icon>
        </button>
        <h1 class="page-title">Manage templates</h1>
      </div>

      <!-- Loading State -->
      <div class="loading-container" *ngIf="isLoading">
        <mat-spinner diameter="40"></mat-spinner>
      </div>

      <!-- Templates Table -->
      <div class="table-container" *ngIf="!isLoading">
        <table mat-table [dataSource]="templates" class="templates-table">

          <!-- Name Column -->
          <ng-container matColumnDef="name">
            <th mat-header-cell *matHeaderCellDef>Name</th>
            <td mat-cell *matCellDef="let template">{{ template.name }}</td>
          </ng-container>

          <!-- Creation Date Column -->
          <ng-container matColumnDef="creationDate">
            <th mat-header-cell *matHeaderCellDef>Creation date</th>
            <td mat-cell *matCellDef="let template">{{ template.creationDate | date: 'MMMM d, y' }}</td>
          </ng-container>

          <!-- Delete Column -->
          <ng-container matColumnDef="delete">
            <th mat-header-cell *matHeaderCellDef>Delete</th>
            <td mat-cell *matCellDef="let template">
              <div class="action-cell">
                <!-- Delete Icon Button -->
                <button
                  mat-icon-button
                  class="delete-icon-btn"
                  [matTooltip]="'Delete ' + template.name"
                  (click)="openDeleteDialog(template)"
                >
                  <mat-icon>delete_outline</mat-icon>
                </button>

                <!-- More Options Menu -->
                <button mat-icon-button [matMenuTriggerFor]="rowMenu">
                  <mat-icon>more_vert</mat-icon>
                </button>

                <mat-menu #rowMenu="matMenu">
                  <button mat-menu-item (click)="renameTemplate(template)">
                    <span>Rename</span>
                  </button>
                  <button mat-menu-item (click)="editTemplate(template)">
                    <span>Edit</span>
                  </button>
                </mat-menu>
              </div>
            </td>
          </ng-container>

          <tr mat-header-row *matHeaderRowDef="displayedColumns"></tr>
          <tr mat-row *matRowDef="let row; columns: displayedColumns;"></tr>

          <!-- Empty State Row -->
          <tr class="mat-row" *matNoDataRow>
            <td class="mat-cell no-data-cell" [attr.colspan]="displayedColumns.length">
              No templates found.
            </td>
          </tr>
        </table>
      </div>
    </div>
  `,
  styles: [`
    .manage-templates-container {
      padding: 24px;
      max-width: 900px;
      font-family: 'Roboto', sans-serif;
    }

    .page-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 24px;
    }

    .back-btn {
      color: #5c35b5;
    }

    .page-title {
      font-size: 20px;
      font-weight: 500;
      margin: 0;
      color: #1a1a2e;
    }

    .loading-container {
      display: flex;
      justify-content: center;
      padding: 48px 0;
    }

    .table-container {
      border: 1.5px solid #7c4dff;
      border-radius: 8px;
      overflow: hidden;
    }

    .templates-table {
      width: 100%;
    }

    .mat-mdc-header-row {
      background-color: #fafafa;
    }

    .mat-mdc-header-cell {
      font-weight: 600;
      color: #444;
      font-size: 13px;
    }

    .mat-mdc-cell {
      color: #333;
      font-size: 14px;
    }

    .mat-mdc-row:hover {
      background-color: #f5f0ff;
    }

    .action-cell {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .delete-icon-btn {
      color: #666;
    }

    .delete-icon-btn:hover {
      color: #d32f2f;
    }

    .no-data-cell {
      text-align: center;
      padding: 32px;
      color: #888;
    }
  `]
})
export class ManageTemplatesComponent implements OnInit, OnDestroy {
  templates: TemplateItem[] = [];
  displayedColumns: string[] = ['name', 'creationDate', 'delete'];
  isLoading = false;

  private destroy$ = new Subject<void>();

  constructor(
    private templateService: TemplateService,
    private dialog: MatDialog,
    private snackBar: MatSnackBar
  ) {}

  ngOnInit(): void {
    this.loadTemplates();
  }

  ngOnDestroy(): void {
    this.destroy$.next();
    this.destroy$.complete();
  }

  loadTemplates(): void {
    this.isLoading = true;

    // Replace 'getTemplateRequests' with your actual service method name
    this.templateService.getTemplateRequests()
      .pipe(takeUntil(this.destroy$))
      .subscribe({
        next: (data) => {
          this.templates = data;
          this.isLoading = false;
        },
        error: (err) => {
          console.error('Failed to load templates:', err);
          this.isLoading = false;
          this.snackBar.open('Failed to load templates. Please try again.', 'Close', {
            duration: 4000
          });
        }
      });
  }

  openDeleteDialog(template: TemplateItem): void {
    const dialogRef = this.dialog.open(DeleteTemplateDialogComponent, {
      width: '400px',
      data: { template }
    });

    dialogRef.afterClosed().subscribe((confirmed: boolean) => {
      if (confirmed) {
        this.deleteTemplate(template);
      }
    });
  }

  deleteTemplate(template: TemplateItem): void {
    // Replace with your actual delete service call
    this.templateService.deleteTemplate(template.id)
      .pipe(takeUntil(this.destroy$))
      .subscribe({
        next: () => {
          this.templates = this.templates.filter(t => t.id !== template.id);
          this.snackBar.open('Template deleted successfully.', 'Close', { duration: 3000 });
        },
        error: (err) => {
          console.error('Failed to delete template:', err);
          this.snackBar.open('Failed to delete template. Please try again.', 'Close', { duration: 4000 });
        }
      });
  }

  renameTemplate(template: TemplateItem): void {
    // Implement rename logic / open rename dialog
    console.log('Rename:', template);
  }

  editTemplate(template: TemplateItem): void {
    // Implement edit navigation or dialog
    console.log('Edit:', template);
  }

  goBack(): void {
    // Implement navigation back
    window.history.back();
  }
}
